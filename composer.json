{
    "name": "dowscripts/scripts",
    "description": "Multi-marketplace (Shopify, Amazon, eBay, Walmart) product metadata + SEO tooling.",
    "type": "project",
    "require": {
        "php": ">=8.2",
        "anthropic-ai/sdk": "^0.31.0",
        "benmorel/ebay-sdk-php": "^19.3",
        "dvicklund/ebay-oauth-php-client": "^1.2",
        "highsidelabs/walmart-api": "^0.7.0",
        "jlevers/selling-partner-api": "^7.4",
        "openai-php/client": "^0.10.3",
        "shopify/shopify-api": "^6.1.1",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "Ige\\Amazon\\": "marketplaces/lib/Amazon/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
