# Dependencies
/vendor/

# Python bytecode cache
__pycache__/
*.pyc

# Secrets
.env

# Logs / sessions
*.log
/tmp/php_sessions/

# OS / editor cruft
.DS_Store
*~

# Amazon SP-API — regenerable per-account data (API-fetched snapshots + audit output)
# Committed: amazon/data/schemas/, amazon/data/*/drafts/, amazon/data/*/drift/
#   (drift/ = deterministic digest of input/ for tracking catalog drift over time)
amazon/data/*/input/
amazon/data/*/output/*.csv
amazon/data/*/output/*.txt

# Claude Code — not project config, no need to share
.claude/
