# Dependencies
/vendor/

# Python bytecode cache
__pycache__/
*.pyc

# Secrets
.env

# Logs / sessions
*.log
/tmp/php_sessions/

# OS / editor cruft
.DS_Store
*~

# --- Generated marketplace data (regenerable; keep it out of git going forward) ---
# These rules only stop NEW pulled/generated files from accumulating. Human-authored
# and reviewable reference data stays tracked on purpose:
#   Amazon — data/schemas/, data/*/drafts/, data/*/drift/
#   eBay   — data/aspects/ (Taxonomy schema cache), data/*/drafts/
#   Shopify— data/drafts/ (authored descriptions/alts)
marketplaces/amazon/data/*/input/
marketplaces/amazon/data/*/output/*.csv
marketplaces/amazon/data/*/output/*.txt
marketplaces/ebay/data/*/output/
marketplaces/ebay/data/*/backups/
marketplaces/shopify/data/input/
marketplaces/shopify/data/output/

# Claude Code — not project config, no need to share
.claude/
