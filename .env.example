# Copy to .env and fill in. .env is gitignored — never commit real credentials.
# Grouped by marketplace; only Shopify is wired up today.

# ============================================================
# Shopify
# ============================================================
# The *.myshopify.com admin domain for the store.
SHOP_DOMAIN=your-store.myshopify.com

# Custom app Admin API access token (starts with shpat_).
# Settings -> Apps and sales channels -> Develop apps -> your app -> API credentials.
# Read-only work (audits/exports) needs read_products.
# Writing (apply_metadata.php) needs write_products.
ADMIN_API_TOKEN=shpat_xxx

# Admin API version.
API_VERSION=2026-04

# Custom app API key / secret. The GraphQL client only needs the domain + token,
# but Context::initialize() wants these populated. Safe to leave as placeholders.
APP_API_KEY=custom-app
APP_API_SECRET=custom-app

# ============================================================
# Amazon  (placeholder — not implemented yet)
# ============================================================
# AMAZON_SP_API_REFRESH_TOKEN=
# AMAZON_SP_API_CLIENT_ID=
# AMAZON_SP_API_CLIENT_SECRET=

# ============================================================
# eBay  (per-account; see ebay/PLAN.md)
# ============================================================
# IMPORTANT: eBay OAuth tokens/credentials contain '#' (e.g. v^1.1#i^1#...).
# In .env you MUST wrap any value containing '#' in double quotes, or phpdotenv
# truncates it at the first '#' (turning a token into just "v^1.1"). When in
# doubt, quote every EBAY_API_* value.
#
# We REUSE the company's existing eBay app (the one Usurper uses) — no new app.
# Schema matches Usurper: DOWS = the default EBAY_API_* block, IGE = the _IGE block.
# Get PRODUCTION values from Scott / prod secrets (sandbox has no real listings).
# Auth is OAuth (app token for Taxonomy; per-account user token + refresh for
# Trading/Feed) — NOT Auth'n'Auth.
EBAY_API_MODE=production
EBAY_API_SITE_ID=0

# --- DOWS ("DealsOnly") ---
EBAY_API_APP_ID=             # Client ID
EBAY_API_CERT_ID=            # Client Secret
EBAY_API_DEV_ID=
EBAY_API_RU_NAME=            # OAuth redirect profile
EBAY_API_REFRESH_TOKEN=      # per-seller OAuth refresh token (mints user tokens)

# --- IGE ("Irongate Enterprises") ---
EBAY_API_APP_ID_IGE=
EBAY_API_CERT_ID_IGE=
EBAY_API_DEV_ID_IGE=
EBAY_API_RU_NAME_IGE=
EBAY_API_REFRESH_TOKEN_IGE=

# ============================================================
# Walmart  (per-country; US is highest priority, CA is second)
# ============================================================
# SDK: highsidelabs/walmart-api. Auth is OAuth2 client_credentials (Configuration::
# getAccessToken() mints/caches the token automatically from clientId+clientSecret —
# no separate refresh-token step like eBay).
#
# Walmart Marketplace Canada is migrating to the unified Global APIs by 2026-07-31;
# after migrating, generate NEW API keys in the CA Developer Portal (old
# certificate-based CA keys will stop working) and put them in the _CA block below.
# The client itself doesn't need code changes for this — same host
# (https://marketplace.walmartapis.com), same client_credentials flow.

# --- US (highest priority) ---
WALMART_CLIENT_ID_US=
WALMART_CLIENT_SECRET_US=

# --- CA ---
WALMART_CLIENT_ID_CA=
WALMART_CLIENT_SECRET_CA=
