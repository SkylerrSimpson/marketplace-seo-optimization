        "product_description": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Need to leave a note for someone, but don't want to them to be able to show anyone else? The disappearing ink pen will allow you to do just that.<br/><br/>This special formula was developed during the Cold War and is now encapsulated within the discreet gel pen for general use. Once on the paper, the ink will appear normally for about 15 minutes. Within an hour, the message will have completely vanished and will be unrecoverable; even with ultraviolet light.<br/><br/>Note: deconstruction time of the ink will vary depending on ambient conditions.",
                    "marketplace_id": "ATVPDKIKX0DER"
                }
            ],
            "is_required": true,
