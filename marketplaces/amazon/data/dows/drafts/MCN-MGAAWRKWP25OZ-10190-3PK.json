        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Fix rips and patch leaks permanently on fishing waders, wetsuits and neoprene with the Aquaseal FD Repair Kit",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Use this flexible urethane adhesive, which bonds to all types of surfaces and outdoor materials including GORE-TEX fabric",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Get a water-tight seal that won’t peel or crack over time with this durable, urethane adhesive",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Be back in the water within minutes using this all-in-one kit; includes 0.25 oz of Aquaseal FD and two 3” Tenacious Tape Repair Patches (clear and black)",
