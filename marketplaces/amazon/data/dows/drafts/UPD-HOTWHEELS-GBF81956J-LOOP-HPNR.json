        "educational_objective": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "​Hot Wheels® Loop Stunt Champion™ is an awesome playset with an exciting dual-track loop and stunting mechanism that brings hours and hours of challenges and racing.",
