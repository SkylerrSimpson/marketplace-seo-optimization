        },
        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "HEROCLIP is the world's first 3-in-1 clip and hook that can hang just about anything, just about anywhere!",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "HANG STUFF SECURELY: Heroclip Medium can hold up to 60 lbs and the rubber tip creates optimal grip so your stuff stays secure.",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "COMPACT DESIGN: Hook and clip nest together when not in use. SIZE MEDIUM gate clearance 1.5\", hook clearance 1.8\", dimensions when open 3\" x 3.75\".",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
