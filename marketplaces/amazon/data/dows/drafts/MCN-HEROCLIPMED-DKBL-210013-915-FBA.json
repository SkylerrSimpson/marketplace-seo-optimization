        "item_name": {
            "value": "HEROCLIP Carabiner Clip and Hook (Medium) for Camping, Backpack, and Garage (Dark Blue)",
            "is_required": true,
            "source": "usurper",
            "usurper_column": "name"
        },
        "product_description": {
            "value": "Heroclip Medium gear clip lets you hook and hang big backpacks from trees, duffle bags from fences, buckets from ladders, and carry-ons from bathroom stalls. This versatile gear clip hangs securely, rotates 360 degrees, and folds compactly in ways other carabiners, clips and hooks can’t, helping you keep your gear organized and exactly where you want it, no matter the activity. \n\nThe clip also features a wider clip gate compared to standard carabiners and hooks, and a hook with a grippy rubber tip for hanging things from flat surfaces.\n\nPLEASE NOTE: This product is not designed for climbing.",
            "is_required": true,
            "source": "usurper",
            "usurper_column": "description"
        },
        "brand": {
            "value": [
