        "product_description": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Going treasure hunting? Then you need the ASR Outdoor 8.5\" Green Sand Scooper.<br/><br/>This sand scooper is super lightweight, making it ideal for scooping up sand to shake out treasures on dry, sandy beaches. Since it's constructed of durable plastic, it wont interfere with your metal detector making it easier to find treasure. <br/><br/>Simply use your metal detector to locate the target area, scoop up some sand in the target area and run the metal detector over the scoop. Then, gently shake the scoop side to side, allowing the sand to fall out of the holes and uncover the treasure. Make sure you have one of these before your next treasure hunt.",
                    "marketplace_id": "ATVPDKIKX0DER"
                }
            ],
            "is_required": true,
