    "attributes": {
        "item_name": {
            "value": "GEAR AID Revivex Nubuck Suede Protector and Fabric Water Repellent",
            "is_required": true,
            "source": "usurper",
            "usurper_column": "name"
        },
        "product_description": {
            "value": "Get prepared for the unpredictable spring weather by waterproofing your footwear and gloves. This protectant works with nubuck, suede, fabric and leather materials; Revivex will not soften your leather! \n\nNote: these leather materials must be using GORE-TEX fabric, eVEnt, and other waterproof-breathable technologies.",
            "is_required": true,
            "source": "usurper",
            "usurper_column": "description"
        },
        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Reduce wear, protect shoes and boots from the elements and keep them looking good as new with this suede and fabric water repellent",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "PFAS-free with zero fluorocarbons, this formula is ideal for use on waterproof-breathable footwear fabrics such as nubuck, leather, canvas, and GORE-TEX",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Maximize breathability of waterproof-breathable shoes to keep your feet feeling cool and dry; available in 4 fl oz bottle",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Enhance the performance of various footwear with natural and technical fabrics on hiking boots, UGGS, and sneakers",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
