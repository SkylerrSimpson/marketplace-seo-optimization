        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Includes four sticker sheets featuring two unique designs, repeated for added variety; perforated sheets allow for easy tearing and sharing",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Officially licensed stickers with a cast and cure treatment that adds a sparkling effect; perfect for decorating water bottles, laptops, phones, and other smooth surfaces",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Contains over 50 stickers in a mix of shapes and sizes ranging from 1 to 3 inches; safe, non-toxic, and ideal for kids ages three and up to enjoy for crafting or creative play",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Designed to adhere securely to clean, flat surfaces; not suitable for rough or uneven surfaces to ensure the best results",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Packaged in a compact polybag for easy storage and portability; dimensions measure 8.25 x 4 inches (21 x 10 cm) and feature FSC-certified materials delivering reliable quality and responsible production",
