        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Restore loft and wash down jackets, vests, sleeping bags and more with Revivex Down Cleaner (10 fl oz); even works with down-filled pillows, comforters, and treated down",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Use this concentrated and gentle detergent without added fragrances, softeners or optical brighteners; cleans 10 jackets or 5 sleeping bags",
