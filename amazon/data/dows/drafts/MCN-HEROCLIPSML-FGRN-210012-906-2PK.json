        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "HEROCLIP is the world's first 3-in-1 clip and hook that can hang just about anything, just about anywhere!",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "HANG STUFF SECURELY: Heroclip Small can hold up to 50 lbs and the rubber tip creates optimal grip so your stuff stays secure.",
