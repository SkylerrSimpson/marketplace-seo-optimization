        "product_description": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "The Revivex Wash and DWR Care Kit for GORE-TEX fabrics includes everything you need to keep high-tech gear looking good. Select the appropriate kit, all of which include Revivex Pro Cleaner, a tech wash that effectively removes dirt, grime and stains without stripping off gear’s durable water repellent (DWR) coating. Afterwards, add or restore water repellency on jackets, waders, gloves, and other waterproof breathable fabrics using Revivex Wash-In or Durable. Choose a kit with Tenacious Tape Mini Patches so when holes and rips make an appearance, just peel-and-stick for a repair that lasts. Keep gear in tip-top shape with the Revivex Wash and DWR Care Kit.",
                    "marketplace_id": "ATVPDKIKX0DER"
                }
            ],
            "is_required": true,
