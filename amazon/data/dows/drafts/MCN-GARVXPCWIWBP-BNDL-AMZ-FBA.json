        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Clean, restore breathability, and protect GORE-TEX fabric/outerwear from water, dirt and stains to keep it looking and performing like new with this easy to use care system",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Pick the care kit that fits your needs; all kits include 10 fl oz of Revivex Pro Cleaner and 10 fl oz of Wash-In Water Repellent or 10. 5 oz of Durable Water Repellent (DWR) spray, with Tenacious Tape Mini Patches optional",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Use the concentrated Pro Cleaner to wash up to 20 jackets or 10 sleeping bags; restores breathability and removes dirt and grime from GORE-TEX fabric, eVent, NeoShell, Omni-Tech, and more waterproof breathable materials",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Restore waterproofing with our Wash-In Water Repellent, a concentrated, fluorocarbon-free formula that treats up to 10 jackets, or use our breathable, washable DWR, a high-performance spray for insulated and non-insulated outerwear",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Fix tears instantly on GORE-TEX fabric, nylon, polyester and vinyl with peel-and-stick Tenacious Tape Mini Patches; kit includes 3 black nylon and 3 clear 1. 5” x 2. 5” patches",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Packaging may vary",
                    "marketplace_id": "ATVPDKIKX0DER"
                }
            ],
