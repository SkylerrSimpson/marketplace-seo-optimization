        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Repair holes and tears in down jackets, tents, rain gear and other outdoor gear with this fabric, peel-and-stick patch kit",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Use this ultra-strong adhesive tape that permanently bonds to nylon, polyester, GORE-TEX fabric, and vinyl (not for cotton, denim or natural fabrics)",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Cut to size and apply the patches on clean puffy coats, backpacks, ski pants, or gloves; includes six 1.5” x 2.5” and sealed with a waterproof coating",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Choose from all black nylon, all clear, or a combination of black and clear patches; nearly invisible repairs that won’t peel off during a wash",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Preservation, reuse, and the spirit of renewal is at the core of our mission and it’s why we have products you can use to fill that hole in your tent, patch up the leak in your waders, and clean the salt water out of your wetsuit. GEAR AID helps extend the life of your outdoor gear.",
                    "marketplace_id": "ATVPDKIKX0DER"
                }
            ],
            "is_required": true,
