        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Fix rips and holes fast with an ultra-strong, peel-and-stick repair tape that requires no heat or sewing, ideal for use on tents, tarps, jackets, vinyl furniture, and other synthetic materials",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Apply Tenacious Tape to almost anything with its aggressive adhesive that bonds permanently to nylon, mesh, vinyl, rubber and plastic; not recommended for seams, denim, cotton, or natural fabrics",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Make a washable repair sealed with this repair tape featuring a waterproof coating that won’t peel off over time; available in 3”x20” strip",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Use the nylon fabric (black, red, yellow, OD green and coyote), ripstop fabric (sage green and off-white), and clear vinyl for a nearly invisible repair",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Packaging may vary",
                    "marketplace_id": "ATVPDKIKX0DER"
