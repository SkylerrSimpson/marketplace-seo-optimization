                },
                {
                    "language_tag": "en_US",
                    "value": "Fix holes, create toe protector, rebuild worn heels with Aquaseal Shoe Repair Adhesive",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Unaffected by heat or cold, make heavy duty durable shoe repairs that can withstand the elements whether at a jobsite or on a mountaintop",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
