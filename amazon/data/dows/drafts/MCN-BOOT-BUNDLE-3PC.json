        "bullet_point": {
            "value": [
                {
                    "language_tag": "en_US",
                    "value": "Fight UV damage and protect against sunlight exposure with a rubber boot treatment that’s also a neoprene protector",
                    "marketplace_id": "ATVPDKIKX0DER"
                },
                {
                    "language_tag": "en_US",
                    "value": "Prevent cracking and blooming on rubber, neoprene, vinyl and even plastic to restore the appearance of all kinds of boots",
