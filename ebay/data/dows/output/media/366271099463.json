ollapse\">\n                    <ul class=\"nav navbar-nav navbar-right\">\n                        <!-- ADD MENU LINKS HERE. THESE ARE NON-FUNCTIONAL EXAMPLES. -->\n                        <li><a href=\"https://www.ebay.com/str/dealsonlywebstore\">Our Store</a></li>\n                        <li><a href=\"https://www.ebay.com/usr/dealsonlywebstore\">About Us</a></li>\n                        <li><a href=\"https://contact.ebay.com/ws/eBayISAPI.dll?ContactUserNextGen&amp;recipient=dealsonlywebstore\">Contact Us</a></li>\n                    </ul>\n                </div><!--/.nav-collapse -->\n            </div>\n        </div>\n        <div class=\"container\">\n            <div class=\"col-md-6\">\n                <div>\n                    <div class=\"main-image\">\n                        <img src=\"https://s3.amazonaws.com/DOWS_products/1600x1600/sports_outdoors/gold_panning/kit_lg_geodes_hammer_updated.jpg\" class=\"img-responsive\" alt=\"Responsive image\">\n                    </div>\n                </div>\n                <h3>Product Details</h3>\n                <!-- ADD A NEW ROW FOR EACH PRODUCT ATTRIBUTE YOU WANT TO SHOW IN THE TABLE OR YOU CAN REMOVE THE TABLE COMPLETELY-->\n                <div class=\"product-specs\">\n                    <table>\n                        <tbody>\n                            <tr>\n                                <td class=\"attr-left\"><br></td><td class=\"attr-right\"><br></td></tr>\n                            <tr>\n                                <td class=\"attr-left\">Features:</td>\n                                <td class=\"attr-right td-list-item\">5LB GEMSTONE PAYDIRT: Enjoy the thrill of sifting through paydirt and identifying precious gemstones! Each five pound bag is packed with a rich assortment of genuine rough gemstones, (two pounds worth), as well an assortment of tumbled stones, all waiting to be discovered</td>\n                            </tr>\n                            <tr>\n                                <td class=\"attr-left\"></td>\n                                <td class=\"attr-right td-list-item\">TOP QUALITY GEMSTONES: In your paydirt, you’ll discover an assortment of rough gemstones like Amazonite, Rough Amethyst, Carnelian, Citrine, Clear Quartz, Fuchsite, Labradorite, Pyrite, Moonstone, Rose Quartz, Sea Jasper, Smoky Quartz, Tiger Eye and more</td>\n                            </tr>\n                            <tr>\n                                <td class=\"attr-left\"></td>\n                                <td class=\"attr-right td-list-item\">HOW TO USE: Fill a large bucket with water; scoop out paydirt into sifting screen (not included), dip sifting screen into water to remove dirt and repeat with remaining paydirt; sift through material a second time to ensure no rocks or gemstones were missed; then use the gemstone identification chart to identify gemstones!</td>\n                            </tr>\n                            <tr>\n                                <td class=\"attr-left\"></td>\n                                <td class=\"attr-right td-list-item\">ROCKS AND MINERALS COLLECTION: Perfect for hobbyists, rock collectors, and gold prospectors looking for a fun, hands on, outdoor activity</td>\n                            </tr>\n                            <tr>\n                                <td class=\"attr-left\"></td>\n                                <td class=\"attr-right td-list-item\">IDENTIFICATION CHART: Double sided gemstone rocks and mineral collection identification chart and precious gemstone facts sheet makes identifying gemstones easy and fun</td>\n                            </tr>\n                        </tbody>\n                    </table>\n                </div><!-- /product-specs -->\n            </div>\n            <div class=\"col-md-6\">\n                <h1>ASR Outdoor 5lb Rough Gemstone Paydirt Bag Gold Panning Kits (8 Styles)</h1>\n                <h2>MSRP <span class=\"msrp-strike\">99.99</span></h