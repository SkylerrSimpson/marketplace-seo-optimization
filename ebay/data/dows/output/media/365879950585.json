d #FFFFFD;\n\t\t\tpadding: 0.5em 0.5em;\n\t\t\tbackground-color: #add8e6;\n\t\t}\n\t\t.newsletter-btn:hover {\n\t\t\t/*background-color: #68828a;*/\n\t\t\tbackground-color: #8aadb8;\n\t\t}\n\t</style>\n\n\n\t<!-- Static navbar -->\n\t<div class=\"navbar navbar-default\" role=\"navigation\">\n\t\t<div class=\"container\">\n\t\t\t<div class=\"navbar-header\">\n\t\t\t\t<!-- ADD YOUR SELLER NAME OR LOGO HERE -->\n\t\t\t\t<a class=\"navbar-brand\" href=\"https://www.ebay.com/str/dealsonlywebstore\">Deals Only</a>\n\t\t\t</div>\n\t\t\t<div class=\"navbar-collapse collapse\">\n\t\t\t\t<ul class=\"nav navbar-nav navbar-right\">\n\t\t\t\t\t<!-- ADD MENU LINKS HERE. THESE ARE NON-FUNCTIONAL EXAMPLES. -->\n\t\t\t\t\t<li><a href=\"https://www.ebay.com/str/dealsonlywebstore\">Our Store</a></li>\n\t\t\t\t\t<li><a href=\"https://www.ebay.com/usr/dealsonlywebstore\">About Us</a></li>\n\t\t\t\t\t<li><a href=\"https://contact.ebay.com/ws/eBayISAPI.dll?ContactUserNextGen&amp;recipient=dealsonlywebstore\">Contact Us</a></li>\n\t\t\t\t</ul>\n\t\t\t</div><!--/.nav-collapse -->\n\t\t</div>\n\t</div>\n\t<div class=\"container\">\n\t\t<div class=\"col-md-6\">\n\t\t\t<div>\n\t\t\t\t<div class=\"main-image\">\n\t\t\t\t\t<img src=\"https://s3.amazonaws.com/usurper-products/37834/ASRO_5pc_3oz_paydirt_kit_updated_2023_parent.jpg\" class=\"img-responsive\" alt=\"Responsive image\">\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t\t<h3>Product Details</h3>\n\t\t\t<!-- ADD A NEW ROW FOR EACH PRODUCT ATTRIBUTE YOU WANT TO SHOW IN THE TABLE OR YOU CAN REMOVE THE TABLE COMPLETELY-->\n\t\t\t<div class=\"product-specs\">\n\t\t\t\t<table>\n\t\t\t\t\t<tbody>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td class=\"attr-left\">MPN:</td>\n\t\t\t\t\t\t\t<td class=\"attr-right\">5PCGOLD</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td class=\"attr-left\">UPC:</td>\n\t\t\t\t\t\t\t<td class=\"attr-right\">810058485373</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td class=\"attr-left\">Features:</td>\n\t\t\t\t\t\t\t<td class=\"attr-right td-list-item\">1LB GOLD PAYDIRT: Each beginner gold pan kit comes with a 1 pound bag of paydirt (total weight) and each pay dirt bag contains fine gold flour and coarse gold flakes in the 20-30 mesh size range; Sealed in premium resealable bag</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td class=\"attr-left\"></td>\n\t\t\t\t\t\t\t<td class=\"attr-right td-list-item\">DUAL RIFFLE GOLD PAN: Best in class 12 inch gold pan has large and shallow riffle side wall, allowing better separation of gold from other material; lightweight, high contrast colors with carabiner hole</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td class=\"attr-left\"></td>\n\t\t\t\t\t\t\t<td class=\"attr-right td-list-item\">FINE GOLD RECOVERY TOOLS - (1) 3oz capacity gold snuffer bottle designed to suction pick up gold flakes and gold flour; (2) small glass vials with screw cap (1 dram and 1 2/3 dram capacity)</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td class=\"attr-left\"></td>\n\t\t\t\t\t\t\t<td class=\"attr-right td-list-item\">12 INCH GOLD PAN: Rough up the gold pan before first use, seasoning the pan by washing off all factory production oils</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t\t<tr>\n\t\t\t\t\t\t\t<td class=\"attr-left\"></td>\n\t\t\t\t\t\t\t<td class=\"attr-right td-list-item\">SPECIFICATIONS: Materials: plastic, metal, glass, paydirt; Colors: green; Glass vial capacity: 1 dram (.065oz), 1 2/3 dram (.1oz) air tight plastic lid; Dual Riffle Gold Pan size: 12” diameter;</td>\n\t\t\t\t\t\t</tr>\n\t\t\t\t\t</tbody>\n\t\t\t\t</table>\n\t\t\t</div><!-- /product-specs -->\n\t\t</div>\n\t\t<div class=\"col-md-6\">\n\t\t\t<h1>ASR Outdoor Gold Panning Kit with Paydirt Beginner Prospecting Tools (3 Colors)</h1>\n\t\t\t<h2>MSRP <span class=\"msrp-strike\">59.99</span></h2>\n\t\t\t<p>Learn how to pan for gold with this six piece ASR Outdoor gold pan kit for beginners. This exciting new prospecting starter gold panning kit includes engineered gold paydirt by professional prospector Bobby Bo. With this kit, you'll be able to learn and practice gold panning techniques at home without having to travel to a claim site.\n\nThe ASR Outdoor six piece gold panning kit is an excellent option for kids and beginners who are just getting started in gold prospecting. Inside the kit, we’ve included six essential prospecting equipment tools to learn the basics of gold panning. You'll find a 12\" dual riffle gold pan that will help you start identifying and collecting gold. There is a 3oz gold snifter bottle that can be used to grab small gold flakes at the bottom of your gold pan, fill it with water to suck up your small gold pickers and use the included glass collection vials to safely store them.\n\nWe partnered with Bobby Bo to bring you this fun beginner gold pan gold panning kit for beginners, so you can watch online videos and follow along at home before heading out into the field. Bobby Bo gold paydirt is packed with size 20 and size 30 mesh coarse gold flake and fine gold flour with nearly no black sand or magnetite, so you will not have to do any classification work to find your gold in the included paydirt. This bag of paydirt gold was expertly designed to practice gold prospecting techniques, not to make you rich. Bobby Bo is a gold prospecting expert who specializes in teaching classes of all ages about gold panning and gold mining.\n\nGrab this kit for yourself, a friend or family member who enjoys outdoor activities like camping and hiking. Its fun to find gold out it nature but learning how with the proper techniques is your first step in this fun outdoor hobby.\n\nGood luck and we hope you have a lot of fun with this paydirt gold pan gold panning kit!</p>\n\t\t\t<div class=\"d-flex d-flex-col grid-60 center text-center bg-grey\">\n\t\t\t\t<div class=\"newsletter-header m-all-1rem all-caps\">Newsletter</div>\n\t\t\t\t<div class=\"grid-100\">\n\t\t\t\t\t<p>SUBSCRIBE for Early Access to Sales</p>\n\t\t\t\t\t<p>Up to 90% Off</p>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"grid-80 center\">\n\t\t\t\t\t<a class=\"newsletter-link\" href=\"https://my.ebay.com/ws/eBayISAPI.dll?AcceptSavedSeller&amp;sellerid=dealsonlywebstore\" target=\"_blank\">\n\t\t\t\t\t\t<div class=\"newsletter-btn all-caps\">Sign Up</div>\n\t\t\t\t\t</a>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div><!-- /col-md-6 -->\n\t\t<div class=\"col-md-12 footer\">\n\t\t\t<p>© 2025</p>\n\t\t</div> <!-- /footer -->\n\n\t</div> <!-- /container -->\n\t<div style=\"clear:both\">\n\t\t&nbsp;<table></table>\n\t</div>\n\n <br>",
