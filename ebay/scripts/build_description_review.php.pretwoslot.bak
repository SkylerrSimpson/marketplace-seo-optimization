<?php

declare(strict_types=1);

/**
 * build_description_review.php — assemble the DRY-RUN description review sheet
 * for Ethan from the authored rewrite copy. NO eBay writes.
 *
 * Reads:
 *   desc_rewrite_answers.jsonl  one line/listing of authored COPY:
 *     {item_id, treatment, headline, intro, bullets:[...]}
 *     - treatment 'copy_rewrite'/'restructure' (tier-1): render a full clean
 *       SEO template (headline + intro + selling bullets + auto specs + schema).
 *     - treatment 'tier2_tweak' (tier-2): keep the listing's existing good HTML,
 *       just PREPEND a keyword-rich lead paragraph (and append an auto specs list
 *       if the body never mentions key aspects). Surgical; preserves everything.
 *   media/{itemId}.json   current description HTML + price (audit_media.php)
 *   items/{itemId}.json   aspects, for the auto specs section (enrich_listings.php)
 *   description_audit.csv  the before-score + issues (for the reviewer's context)
 *
 * Writes:
 *   description_review.csv  one row/listing: current vs proposed HTML, before
 *     score, issues, what changed, + blank approved / reviewer_notes columns.
 *   descriptions/{itemId}.html  the full proposed HTML (easier to eyeball/diff).
 *
 * The specs section is generated FROM the listing's own aspects, so aspect
 * coverage is guaranteed without the author hand-listing them.
 *
 * Usage: php ebay/scripts/build_description_review.php --account=dows|ige
 */

require __DIR__ . '/../../lib/bootstrap.php';

$opts    = getopt('', ['account:', 'help']);
if (isset($opts['help'])) { fwrite(STDOUT, "Usage: php build_description_review.php --account=dows|ige\n"); exit(0); }
$account = strtolower((string) ($opts['account'] ?? 'dows'));
$outDir  = ebay_dir($account, 'output');
$mediaDir = $outDir . '/media';
$itemDir  = $outDir . '/items';
$descDir  = $outDir . '/descriptions';
if (!is_dir($descDir)) { mkdir($descDir, 0775, true); }

// Store directory — drives the header brand + Our Store / Contact Us links and the
// footer, exactly like the description generator's dropdown. Slugs verified from
// the accounts' own live listing HTML.
$STORES = [
    'dows' => ['brand' => 'Deals Only Webstore',  'slug' => 'dealsonlywebstore'],
    'ige'  => ['brand' => 'Irongate Enterprises', 'slug' => 'irongateamericansupply'],
];
$store = $STORES[$account] ?? $STORES['dows'];

$ansPath = $outDir . '/desc_rewrite_answers.jsonl';
if (!is_file($ansPath)) {
    fwrite(STDERR, "No authored answers at {$ansPath}.\n");
    exit(1);
}

// audit context (before-score + issues) keyed by item_id
$auditCtx = [];
$ap = $outDir . '/description_audit.csv';
if (is_file($ap)) {
    $fh = fopen($ap, 'r'); $h = fgetcsv($fh);
    while (($r = fgetcsv($fh)) !== false) { $row = array_combine($h, $r); $auditCtx[$row['item_id']] = $row; }
    fclose($fh);
}

// Plain-English labels for the reviewer (Ethan). EVERY listing is now re-rendered
// into the one canonical template, so the label describes how much the COPY changed.
$CHANGE_LABEL = [
    'copy_rewrite' => 'Full rewrite + standardized',
    'restructure'  => 'Full rebuild + standardized',
    'tier2_tweak'  => 'Copy improved + standardized',
    'valid'        => 'Reformatted to standard style (copy kept)',
];

// Load the authored rewrites (the 188) into a map; everything else is normalized
// from its own clean short_description.
$authored = [];
foreach (file($ansPath, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
    $a = json_decode($line, true);
    if (is_array($a) && ($a['item_id'] ?? '') !== '') { $authored[(string) $a['item_id']] = $a; }
}

$rev = fopen($outDir . '/description_review.csv', 'w');
fputcsv($rev, ['item_id','sku','title','price','change_type','score_before','issues_before',
    'prev_description','new_description','prev_html','proposed_html','what_changed',
    'current_html_len','proposed_html_len','approved','reviewer_notes']);

$oneLine = fn(string $s) => trim(preg_replace('/\s+/u', ' ', $s));

$byTreat = []; $total = 0;
// Iterate EVERY listing (flagged first, in authored order, then the rest) so the
// 188 worked listings stay at the top of the sheet.
$order = array_merge(array_keys($authored), array_keys($auditCtx));
$seenId = [];
foreach ($order as $id) {
    $id = (string) $id;
    if (isset($seenId[$id])) { continue; }
    $seenId[$id] = true;

    $media   = readJson($mediaDir . "/{$id}.json");
    $item    = readJson($itemDir . "/{$id}.json");
    $aspects = is_array($item['aspects'] ?? null) ? $item['aspects'] : [];
    $ctx     = $auditCtx[$id] ?? [];

    $title       = (string) ($media['title'] ?? ($ctx['title'] ?? ''));
    $price       = (string) ($media['price'] ?? '');
    $currentHtml = (string) ($media['description'] ?? '');
    $shortDesc   = trimBoiler((string) ($media['short_description'] ?? ''));
    $imageUrl    = (string) ($media['images'][0]['url'] ?? '');

    $a = $authored[$id] ?? null;
    if ($a !== null) {
        // one of the 188 authored rewrites
        $treatment = (string) ($a['treatment'] ?? 'copy_rewrite');
        $headline  = trim((string) ($a['headline'] ?? '')) ?: $title;
        $authIntro = trim((string) ($a['intro'] ?? ''));
        $bullets   = array_values(array_filter(array_map('trim', (array) ($a['bullets'] ?? []))));
        if ($treatment === 'tier2_tweak') {
            // good copy already: keep the keyword lead, then the listing's clean
            // narrative; pull real feature bullets from the old HTML.
            $intro   = $oneLine($authIntro . ' ' . $shortDesc);
            $bullets = extractFeatures($currentHtml);
            $summary = 'Copy was solid: kept a keyword-rich lead + the original description text, '
                . 'cleaned the boilerplate, and re-rendered in the standard template.';
        } else {
            $intro   = $authIntro;
            $summary = 'Weak/duplicate copy rewritten (keyword headline, intro, selling bullets) '
                . 'and rendered in the standard template.';
        }
    } else {
        // already-valid: keep its copy, just normalize the HTML style.
        $treatment = 'valid';
        $headline  = $title;
        $intro     = $shortDesc !== '' ? $shortDesc : cleanText($currentHtml);
        if ($intro === '') { $intro = $title; }
        $bullets   = extractFeatures($currentHtml);
        $summary   = 'Description copy unchanged; HTML reformatted to the standard '
            . 'template (removed store boilerplate / mobile blocks; added schema + specs).';
    }

    // Strip identifier gibberish (MPN/UPC/SKU/EAN/GTIN ...) from the human-readable
    // copy — it belongs in the Product Specifications list, never the description or
    // the mobile summary. If stripping empties the intro (some short_descriptions are
    // ONLY a part number), fall back to the cleaned body, then the title.
    $intro   = stripIdentifiers($intro);
    if (mb_strlen($intro) < 15) {
        $alt   = stripIdentifiers(cleanText($currentHtml));
        $intro = mb_strlen($alt) >= 15 ? $alt : $title;
    }
    $bullets = array_values(array_filter(
        array_map('stripIdentifiers', $bullets), fn($b) => $b !== ''));

    // The hidden mobile summary eBay requires (tag-free, <=800 chars) — derived
    // from the proposed intro, same field the generator exposes.
    $mobile   = mobileSummary($intro);
    $proposed = renderFull($store, $title, $headline, $intro, $mobile, $bullets, $aspects, $imageUrl);
    file_put_contents($descDir . "/{$id}.html", $proposed);

    // new_description = the readable proposed COPY (intro + features), without the
    // header/footer/mobile chrome, so Ethan reads the prose not the store nav.
    $newText = $oneLine($intro . ' ' . implode(' ', $bullets));

    // Before/after, both as readable text (HTML stripped) and as raw HTML, each
    // collapsed to ONE physical line so spreadsheet tools don't under-count rows.
    fputcsv($rev, [
        $id, $ctx['sku'] ?? '', $title, $price, $CHANGE_LABEL[$treatment] ?? $treatment,
        $ctx['score'] ?? '', $ctx['issues'] ?? '',
        $oneLine(strip_tags($currentHtml)), $newText,
        $oneLine($currentHtml), $oneLine($proposed), $summary,
        strlen($currentHtml), strlen($proposed), '', '',
    ]);
    $byTreat[$treatment] = ($byTreat[$treatment] ?? 0) + 1;
    $total++;
}
fclose($rev);

echo "=== description review built: {$account} ===\n";
printf("total listings (all standardized): %d\n", $total);
foreach ($byTreat as $k => $v) { printf("  %-13s %d\n", $k, $v); }
echo "  {$outDir}/description_review.csv\n  {$descDir}/{itemId}.html\n";

// --- renderers -----------------------------------------------------------------

/**
 * THE canonical description template — byte-for-byte what ebay/tools/description-
 * generator.html emits, so the review sheet shows exactly what a listing would look
 * like if authored through the generator. One schema.org/Product block:
 *   hidden mobile description (the eBay-required mobile summary, display:none)
 *   store header (brand + Our Store / Contact Us links for this account)
 *   keyword H2 -> intro <p> -> Key Features (Label: detail bolds the label)
 *   -> main image -> Product Specifications (from aspects) -> store footer.
 */
function renderFull(array $store, string $title, string $headline, string $intro,
    string $mobile, array $bullets, array $aspects, string $imageUrl): string
{
    $h      = esc($headline !== '' ? $headline : $title);
    $mob    = esc(trim(preg_replace('/\s+/u', ' ', $mobile)));
    $introP = $intro !== '' ? '  <p>' . esc($intro) . "</p>\n" : '';

    // Key Features — "Label: detail" bolds the label (matches the generator).
    $features = '';
    if ($bullets !== []) {
        $li = '';
        foreach ($bullets as $b) {
            $b = trim(preg_replace('/\s+/u', ' ', (string) $b));
            if ($b === '') { continue; }
            $pos = mb_strpos($b, ':');
            if ($pos !== false && $pos > 0) {
                $li .= '    <li><strong>' . esc(mb_substr($b, 0, $pos)) . ':</strong> '
                    . esc(trim(mb_substr($b, $pos + 1))) . "</li>\n";
            } else {
                $li .= '    <li>' . esc($b) . "</li>\n";
            }
        }
        if ($li !== '') {
            $features = "  <h3 style=\"font-size:18px;margin:18px 0 8px\">Key Features</h3>\n"
                . "  <ul style=\"padding-left:20px;margin:0 0 16px\">\n{$li}  </ul>\n";
        }
    }

    $imageHtml = $imageUrl !== ''
        ? '  <p style="text-align:center;margin:0 0 16px"><img src="' . esc($imageUrl)
            . '" alt="' . $h . '" style="max-width:100%;width:600px;height:auto"></p>' . "\n"
        : '';
    $specs   = renderSpecs($aspects);
    $brand   = esc($store['brand']);
    $storeUrl   = esc('https://www.ebay.com/str/' . $store['slug']);
    $contactUrl = esc('https://www.ebay.com/cnt/intermediatedFAQ?requested=' . $store['slug']);
    $year    = date('Y');

    return <<<HTML
<div style="font-family:Arial,Helvetica,sans-serif;font-size:15px;line-height:1.6;color:#222;max-width:800px;margin:0 auto" vocab="https://schema.org/" typeof="Product">
  <div style="display:none"><span property="description">{$mob}</span></div>
  <div style="background:#f5f5f5;padding:12px 15px;border:1px solid #e5e5e5;margin:0 0 16px">
    <div style="font-size:18px;font-weight:bold;margin-bottom:6px">{$brand}</div>
    <div style="font-size:13px">
      <a href="{$storeUrl}" style="margin-right:15px;text-decoration:none;color:#333">Our Store</a>
      <a href="{$contactUrl}" style="text-decoration:none;color:#333">Contact Us</a>
    </div>
  </div>
  <h2 style="font-size:22px;margin:0 0 12px">{$h}</h2>
{$introP}{$features}{$imageHtml}{$specs}  <p style="margin:18px 0 0;padding-top:12px;border-top:1px solid #e5e5e5;font-size:13px;color:#777;text-align:center">&copy; {$year} {$brand}</p>
</div>
HTML;
}

/**
 * The eBay mobile summary: tag-free plain text. eBay counts the characters in the
 * span SOURCE — i.e. AFTER HTML-escaping (&#039; is six characters) — caps at 800,
 * and drops the remainder. So trim whole words until the ESCAPED text fits in 800,
 * never leaving a mid-word truncation for eBay to make.
 */
function mobileSummary(string $intro): string
{
    $t = trim(preg_replace('/\s+/u', ' ', $intro));
    if (escLen($t) <= 800) { return $t; }
    $words = explode(' ', $t);
    while ($words !== [] && escLen(implode(' ', $words)) > 800) { array_pop($words); }
    return rtrim(implode(' ', $words));
}

/** Length of a string once HTML-escaped — what eBay actually counts in the span. */
function escLen(string $s): int { return mb_strlen(esc($s)); }

/**
 * Pull genuine feature bullets out of a listing's existing HTML <li> items,
 * filtering the store-nav / policy boilerplate (Our Store, About Us, Contact Us,
 * Shipping, Returns, MSRP, …) and anything too short or too long to be a feature.
 *
 * @return list<string>
 */
function extractFeatures(string $html): array
{
    if ($html === '' || !preg_match_all('/<li[^>]*>(.*?)<\/li>/is', $html, $m)) { return []; }
    $boiler = '/\b(our (ebay )?store|about us|contact us|add (to )?favou?rite|sign ?up|newsletter|'
        . 'feedback|^returns?$|^shipping$|^payment|return policy|shipping policy|'
        . 'warranty information|view (more|other|all)|msrp|terms|policies?|see (all|more)|'
        . 'home page|store categories|powered by)\b/i';
    $out = []; $seen = [];
    foreach ($m[1] as $raw) {
        $t = trim(preg_replace('/\s+/u', ' ', html_entity_decode(strip_tags($raw), ENT_QUOTES | ENT_HTML5, 'UTF-8')));
        if ($t === '') { continue; }
        $wc = str_word_count($t);
        if ($wc < 3 || $wc > 40) { continue; }          // nav labels too short, paragraphs too long
        if (preg_match($boiler, $t)) { continue; }
        $key = mb_strtolower($t);
        if (isset($seen[$key])) { continue; }
        $seen[$key] = true;
        $out[] = $t;
        if (count($out) >= 6) { break; }
    }
    return $out;
}

/** A "Product Specifications" list rendered from the listing's own aspects. */
function renderSpecs(array $aspects): string
{
    // legal text + internal-only fields that add noise to a customer-facing spec list
    $skip = ['california prop 65 warning', 'unit type', 'unit quantity'];
    $rows = '';
    foreach ($aspects as $name => $val) {
        $val = trim((string) $val);
        if ($val === '' || in_array(mb_strtolower((string) $name), $skip, true)) { continue; }
        $rows .= '    <li><strong>' . esc((string) $name) . ':</strong> ' . esc($val) . "</li>\n";
    }
    if ($rows === '') { return ''; }
    return "  <h3 style=\"font-size:18px;margin:18px 0 8px\">Product Specifications</h3>\n"
        . "  <ul style=\"padding-left:20px;margin:0 0 16px\">\n{$rows}  </ul>\n";
}

/**
 * Clean fallback text when a listing has no short_description: drop script/style
 * blocks and comments (so CSS doesn't leak), strip tags, then cut the store
 * template chrome that follows the real copy (nav, "Product Details", etc.).
 */
function cleanText(string $html): string
{
    $html = preg_replace('#<(script|style)\b[^>]*>.*?</\1>#is', ' ', $html);
    $html = preg_replace('/<!--.*?-->/s', ' ', $html);
    $t = html_entity_decode(strip_tags($html), ENT_QUOTES | ENT_HTML5, 'UTF-8');
    $t = preg_replace('/\s+/u', ' ', (string) $t);
    return trimBoiler((string) $t);
}

/**
 * Remove identifier labels + their values (MPN/UPC/SKU/EAN/GTIN/ISBN/Part No) from
 * human-readable copy. These are machine codes — gibberish in a description and never
 * wanted in the mobile summary (Ethan, 2026-06-23). They remain in Product Specifications.
 */
function stripIdentifiers(string $t): string
{
    $t = preg_replace(
        '/\b(MPN|UPC|EAN|GTIN|SKU|ISBN|Part\s*(?:No\.?|Number|#))\b\s*[:#]?\s*'
        . '[A-Za-z0-9][A-Za-z0-9._\/-]*\.?/i', ' ', $t);
    return trim(preg_replace('/\s+/u', ' ', (string) $t));
}

/** Cut a listing's store-template chrome that trails the real copy (nav, MSRP, etc.). */
function trimBoiler(string $t): string
{
    $t = preg_split('/\b(Deals Only|Our Store|About Us|Contact Us|Product Details|Irongate American|MSRP)\b|Up to \d+% Off/i', $t)[0];
    return trim((string) $t);
}

function esc(string $s): string { return htmlspecialchars($s, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8'); }
function readJson(string $p): array { return is_file($p) ? (json_decode((string) file_get_contents($p), true) ?: []) : []; }
