{% assign price_valid_until = 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d' %}
{% assign clean_desc = product.description | strip_html | strip_newlines %}
{% assign return_days = 30 %}
{% assign return_country = 'US' %}
{% assign jm_rating = product.metafields.reviews.rating.value %}
{% assign jm_count = product.metafields.reviews.rating_count.value | plus: 0 %}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "ProductGroup",
  "@id": "{{ shop.url }}{{ product.url }}#product",
  "name": {{ product.title | json }},
  "description": {{ clean_desc | json }},
  {% if jm_count > 0 %}"aggregateRating": { "@type": "AggregateRating", "ratingValue": "{{ jm_rating.rating }}", "reviewCount": "{{ jm_count }}", "bestRating": "{{ jm_rating.scale_max }}", "worstRating": "{{ jm_rating.scale_min }}" },{% endif %}
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  {% if product.type != blank %}"category": {{ product.type | json }},{% endif %}
  "productGroupID": {{ product.id | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  {% if product.featured_image %}"image": "{{ product.featured_image | image_url: width: 1920 }}",{% endif %}
  "hasVariant": [
    {% for variant in product.variants %}
    {% assign v_img = variant.image | default: product.featured_image %}
    {
      "@id": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}#variant",
      "@type": "Product",
      "name": {{ variant.title | prepend: ' - ' | prepend: product.title | json }},
      "description": {{ clean_desc | json }},
      "sku": {{ variant.sku | json }},
      {% if variant.barcode != blank %}"gtin": {{ variant.barcode | json }},{% endif %}
      {% if v_img %}"image": "{{ v_img | image_url: width: 1920 }}",{% endif %}
      "offers": {
        "@id": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}#offer",
        "@type": "Offer",
        "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "itemCondition": "https://schema.org/NewCondition",
        "price": "{{ variant.price | money_without_currency | replace: ',', '' }}",
        "priceCurrency": {{ shop.currency | json }},
        "priceValidUntil": "{{ price_valid_until }}",
        "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}",
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "applicableCountry": "{{ return_country }}",
          "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
          "merchantReturnDays": {{ return_days }},
          "returnMethod": "https://schema.org/ReturnByMail",
          "returnFees": "https://schema.org/ReturnFeesCustomerResponsibility"
        }
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>

{%- for media in product.media -%}
  {%- if media.media_type == 'external_video' and media.host == 'youtube' -%}
    {%- assign vid = media.external_id -%}
    {%- assign vid_upload = '' -%}
    {%- assign vid_dur = '' -%}
    {%- case vid -%}
      {%- when 'Xepf8uTnR7w' -%}{%- assign vid_upload = '2023-09-21' -%}{%- assign vid_dur = 'PT1M34S' -%}
      {%- when 'XdsMWcP7A0g' -%}{%- assign vid_upload = '2025-04-10' -%}{%- assign vid_dur = 'PT36S' -%}
      {%- when 'I52rzwyfliE' -%}{%- assign vid_upload = '2022-06-15' -%}{%- assign vid_dur = 'PT1M45S' -%}
      {%- when 'OdcvlszXOH0' -%}{%- assign vid_upload = '2022-06-21' -%}{%- assign vid_dur = 'PT4M25S' -%}
      {%- when '3KRzsc-stEE' -%}{%- assign vid_upload = '2022-06-15' -%}{%- assign vid_dur = 'PT1M33S' -%}
      {%- when 'vW6hZTmYAqc' -%}{%- assign vid_upload = '2022-06-22' -%}{%- assign vid_dur = 'PT2M57S' -%}
      {%- when 'D0Sch7DMcHM' -%}{%- assign vid_upload = '2023-09-25' -%}{%- assign vid_dur = 'PT3M21S' -%}
      {%- when '3N-gFD2G-jQ' -%}{%- assign vid_upload = '2025-09-26' -%}{%- assign vid_dur = 'PT25S' -%}
      {%- when 'KLobXEEdf1Q' -%}{%- assign vid_upload = '2024-09-13' -%}{%- assign vid_dur = 'PT2M59S' -%}
      {%- when 't9Fc9uBs24Y' -%}{%- assign vid_upload = '2024-09-24' -%}{%- assign vid_dur = 'PT1M30S' -%}
      {%- when 'O_ithEcabnU' -%}{%- assign vid_upload = '2026-02-24' -%}{%- assign vid_dur = 'PT23S' -%}
      {%- when 'BX_OnDzxXRA' -%}{%- assign vid_upload = '2022-06-16' -%}{%- assign vid_dur = 'PT3M16S' -%}
      {%- when 'GRGKibzHhNQ' -%}{%- assign vid_upload = '2022-06-16' -%}{%- assign vid_dur = 'PT2M34S' -%}
      {%- when 'o6ToaVuqtZk' -%}{%- assign vid_upload = '2022-06-24' -%}{%- assign vid_dur = 'PT49S' -%}
      {%- when 'xCIlBiVK-hM' -%}{%- assign vid_upload = '2022-06-16' -%}{%- assign vid_dur = 'PT4M3S' -%}
      {%- when 'F3nU7PYk2CU' -%}{%- assign vid_upload = '2022-06-28' -%}{%- assign vid_dur = 'PT2M33S' -%}
    {%- endcase -%}
    {%- if vid_upload == '' -%}{%- assign vid_upload = product.published_at | date: '%Y-%m-%d' -%}{%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "VideoObject",
  "name": {{ product.title | json }},
  "description": {{ clean_desc | json }},
  "thumbnailUrl": "https://i.ytimg.com/vi/{{ vid }}/hqdefault.jpg",
  "uploadDate": "{{ vid_upload }}",
  {% if vid_dur != '' %}"duration": "{{ vid_dur }}",{% endif %}
  "embedUrl": "https://www.youtube.com/embed/{{ vid }}"
}
</script>
  {%- endif -%}
{%- endfor -%}
