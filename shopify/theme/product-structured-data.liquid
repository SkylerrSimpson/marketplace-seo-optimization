{%- comment -%}
  ============================================================================
  Enhanced Product structured data for ASR Outdoor (Dawn 15.4.1)
  ============================================================================
  REPLACES Shopify's built-in `{{ product | structured_data }}` output, which
  emits a ProductGroup + hasVariant but OMITS the fields Google's Merchant
  listings / Product snippets reports want. This snippet mirrors that exact
  structure and ADDS, on every variant and its offer:
    - description            (per variant)         -> fixes "Missing field description" (hasVariant)
    - offers.priceValidUntil                       -> fixes "Missing field priceValidUntil (in hasVariant.offers)"
    - offers.itemCondition
    - offers.hasMerchantReturnPolicy               -> mirrors Merchant Center return policy
    - offers.shippingDetails  (US, see note)       -> mirrors Merchant Center shipping
  Open-web AI crawlers (Perplexity / ChatGPT-browse / Claude) read THIS markup,
  not your Merchant Center account, so the fields matter for AI surfacing too.

  INSTALL (Dawn):
  1. Online Store > Themes > ... > Edit code.
  2. Open sections/main-product.liquid and find the block:
         <script type="application/ld+json">
           {{ product | structured_data }}
         </script>
  3. Replace JUST that block with:
         {% render 'product-structured-data', product: product %}
  4. Save this file as snippets/product-structured-data.liquid.
  5. Test the product URL in Google Rich Results Test (must show 0 errors).

  VALUES TO CONFIRM before publishing (kept in vars at top):
    - return policy: 30 days, customer pays return shipping (ReturnShippingFees),
      US. Matches your Merchant Center "Standard for United States" policy.
    - shipping: US handling 1 business day, transit 4-5 business days, flat rate
      $0.00 placeholder. *** SET shipping_rate to your real US rate (or remove the
      shippingDetails block) so it matches Merchant Center and doesn't mismatch. ***
{%- endcomment -%}

{%- liquid
  assign price_valid_until = 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d'
  assign clean_desc = product.description | strip_html | strip_newlines

  # --- confirm these against Merchant Center before publishing ---
  assign return_days = 30
  assign ship_country = 'US'
  assign ship_currency = shop.currency
  assign ship_rate = '0.00'
  assign ship_handling_min = 0
  assign ship_handling_max = 1
  assign ship_transit_min = 4
  assign ship_transit_max = 5
-%}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "ProductGroup",
  "@id": "{{ shop.url }}{{ product.url }}#product",
  "name": {{ product.title | json }},
  "description": {{ clean_desc | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  {%- if product.type != blank %}
  "category": {{ product.type | json }},
  {%- endif %}
  "productGroupID": {{ product.id | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  {%- if product.featured_image %}
  "image": "{{ product.featured_image | image_url: width: 1920 }}",
  {%- endif %}
  "hasVariant": [
    {%- for variant in product.variants %}
    {%- assign v_img = variant.image | default: product.featured_image -%}
    {
      "@id": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}#variant",
      "@type": "Product",
      "name": {{ variant.title | prepend: ' - ' | prepend: product.title | json }},
      "description": {{ clean_desc | json }},
      "sku": {{ variant.sku | json }},
      {%- if variant.barcode != blank %}
      "gtin": {{ variant.barcode | json }},
      {%- endif %}
      {%- if v_img %}
      "image": "{{ v_img | image_url: width: 1920 }}",
      {%- endif %}
      "offers": {
        "@id": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}#offer",
        "@type": "Offer",
        "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}",
        "price": "{{ variant.price | money_without_currency | replace: ',', '' }}",
        "priceCurrency": "{{ shop.currency }}",
        "priceValidUntil": "{{ price_valid_until }}",
        "itemCondition": "https://schema.org/NewCondition",
        "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "applicableCountry": "{{ ship_country }}",
          "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
          "merchantReturnDays": {{ return_days }},
          "returnMethod": "https://schema.org/ReturnByMail",
          "returnFees": "https://schema.org/ReturnShippingFees"
        },
        "shippingDetails": {
          "@type": "OfferShippingDetails",
          "shippingRate": {
            "@type": "MonetaryAmount",
            "value": "{{ ship_rate }}",
            "currency": "{{ ship_currency }}"
          },
          "shippingDestination": {
            "@type": "DefinedRegion",
            "addressCountry": "{{ ship_country }}"
          },
          "deliveryTime": {
            "@type": "ShippingDeliveryTime",
            "handlingTime": {
              "@type": "QuantitativeValue",
              "minValue": {{ ship_handling_min }},
              "maxValue": {{ ship_handling_max }},
              "unitCode": "DAY"
            },
            "transitTime": {
              "@type": "QuantitativeValue",
              "minValue": {{ ship_transit_min }},
              "maxValue": {{ ship_transit_max }},
              "unitCode": "DAY"
            }
          }
        }
      }
    }{%- unless forloop.last %},{%- endunless %}
    {%- endfor %}
  ]
}
</script>
