{%- comment -%}
  ============================================================================
  FINAL Product structured data for ASR Outdoor (Dawn) — "safe" variant
  ============================================================================
  Replaces Shopify's built-in {{ product | structured_data }} (a ProductGroup +
  hasVariant that OMITS the fields Google's reports want). Mirrors that exact
  structure and ADDS, per variant + offer:
    - description            (per variant)  -> fixes GSC "Missing field description" (hasVariant)
    - offers.priceValidUntil                -> fixes GSC "Missing field priceValidUntil (hasVariant.offers)"
    - offers.itemCondition  (NewCondition)
    - offers.hasMerchantReturnPolicy         -> mirrors Merchant Center return policy
  shippingDetails is intentionally NOT included — Merchant Center already
  supplies verified shipping, and a hardcoded rate could mismatch it.

  INSTALL (do on a DUPLICATED theme first, then publish or copy to live):
  1. Save as snippets/product-structured-data.liquid
  2. In sections/main-product.liquid replace:
       <script type="application/ld+json">{{ product | structured_data }}</script>
     with:
       {% render 'product-structured-data', product: product %}
  3. Preview -> view source -> validate the rendered JSON-LD (Rich Results "Code"
     mode or paste to review) -> 0 errors.

  CONFIRM before publishing (vars below mirror Merchant Center):
    return: 30 days, ReturnByMail, customer pays return shipping (ReturnShippingFees), US.
{%- endcomment -%}
{% assign price_valid_until = 'now' | date: '%s' | plus: 31536000 | date: '%Y-%m-%d' %}
{% assign clean_desc = product.description | strip_html | strip_newlines %}
{% assign return_days = 30 %}
{% assign return_country = 'US' %}
<script type="application/ld+json">
{
  "@context": "https://schema.org/",
  "@type": "ProductGroup",
  "@id": "{{ shop.url }}{{ product.url }}#product",
  "name": {{ product.title | json }},
  "description": {{ clean_desc | json }},
  "brand": { "@type": "Brand", "name": {{ product.vendor | json }} },
  {% if product.type != blank %}"category": {{ product.type | json }},{% endif %}
  "productGroupID": {{ product.id | json }},
  "url": "{{ shop.url }}{{ product.url }}",
  {% if product.featured_image %}"image": "{{ product.featured_image | image_url: width: 1920 }}",{% endif %}
  "hasVariant": [
    {% for variant in product.variants %}
    {% assign v_img = variant.image | default: product.featured_image %}
    {
      "@id": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}#variant",
      "@type": "Product",
      "name": {{ variant.title | prepend: ' - ' | prepend: product.title | json }},
      "description": {{ clean_desc | json }},
      "sku": {{ variant.sku | json }},
      {% if variant.barcode != blank %}"gtin": {{ variant.barcode | json }},{% endif %}
      {% if v_img %}"image": "{{ v_img | image_url: width: 1920 }}",{% endif %}
      "offers": {
        "@id": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}#offer",
        "@type": "Offer",
        "availability": "{% if variant.available %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
        "itemCondition": "https://schema.org/NewCondition",
        "price": "{{ variant.price | money_without_currency | replace: ',', '' }}",
        "priceCurrency": {{ shop.currency | json }},
        "priceValidUntil": "{{ price_valid_until }}",
        "url": "{{ shop.url }}{{ product.url }}?variant={{ variant.id }}",
        "hasMerchantReturnPolicy": {
          "@type": "MerchantReturnPolicy",
          "applicableCountry": "{{ return_country }}",
          "returnPolicyCategory": "https://schema.org/MerchantReturnFiniteReturnWindow",
          "merchantReturnDays": {{ return_days }},
          "returnMethod": "https://schema.org/ReturnByMail",
          "returnFees": "https://schema.org/ReturnShippingFees"
        }
      }
    }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ]
}
</script>
