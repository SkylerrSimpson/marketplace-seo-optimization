{%- comment -%}
  ============================================================================
  BLOG STRUCTURED DATA — Blog + BlogPosting JSON-LD for the blog INDEX page.
  ----------------------------------------------------------------------------
  WHERE TO PASTE: layout/theme.liquid, just before </head> (same spot as the
  breadcrumb snippet). Guarded to render ONLY on the blog index template, so it
  is inert everywhere else. Lists the articles currently shown so Google sees
  the journal as a Blog with these posts. Pulls live data, stays current.
  ============================================================================
{%- endcomment -%}

{%- if template.name == 'blog' and blog -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": "{{ shop.url }}{{ blog.url }}#blog",
  "name": {{ blog.title | json }},
  "url": "{{ shop.url }}{{ blog.url }}",
  "publisher": { "@type": "Organization", "name": {{ shop.name | json }}, "url": "{{ shop.url }}" },
  "blogPost": [
    {%- for article in blog.articles -%}
    {
      "@type": "BlogPosting",
      "headline": {{ article.title | json }},
      "url": "{{ shop.url }}{{ article.url }}",
      {% if article.image %}"image": "{{ article.image | image_url: width: 1200 }}",{% endif %}
      "datePublished": "{{ article.published_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",
      {% if article.updated_at %}"dateModified": "{{ article.updated_at | date: '%Y-%m-%dT%H:%M:%S%z' }}",{% endif %}
      {% if article.excerpt_or_content != blank %}"description": {{ article.excerpt_or_content | strip_html | strip_newlines | truncatewords: 40 | json }},{% endif %}
      "author": { "@type": "Person", "name": {{ article.author | json }} },
      "publisher": { "@type": "Organization", "name": {{ shop.name | json }} }
    }{% unless forloop.last %},{% endunless %}
    {%- endfor -%}
  ]
}
</script>
{%- endif -%}
